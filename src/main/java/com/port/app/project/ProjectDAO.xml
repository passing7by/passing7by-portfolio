<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"https://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.port.app.project.ProjectDAO">
	<resultMap type="ProjectVO" id="detailResult">
		<id column="id" property="id"/>
		
		<result column="admin_id" property="adminId"/>
		<result column="title" property="title"/>
		<result column="summary" property="summary"/>
		<result column="team_size" property="teamSize"/>
		<result column="key_features" property="keyFeatures"/>
		<result column="tech_stack" property="techStack"/>
		<result column="start_date" property="startDate"/>
		<result column="end_date" property="endDate"/>
		<result column="github_url" property="githubUrl"/>
		<result column="demo_url" property="demoUrl"/>
		<result column="ppt_url" property="pptUrl"/>
		<result column="reg_date" property="regDate"/>
		<result column="mod_date" property="modDate"/>
		
		<collection property="projectNoteVOs" javaType="java.util.List" ofType="ProjectNoteVO">
			<id column="id" property="id"/>
			
			<result column="title" property="title"/>
			<result column="url" property="url"/>
		</collection>
		
		<collection property="sectionVOs" javaType="java.util.List" ofType="SectionVO">
			<id column="id" property="id"/>
			
			<result column="title" property="title"/>
			<result column="content" property="content"/>
		</collection>
		
		<collection property="fileVOs" javaType="java.util.List" ofType="FileVO">
			<id column="id" property="id"/>
			
			<result column="ori_name" property="oriName"/>
			<result column="saved_name" property="savedName"/>
			<result column="extension" property="extension"/>
		</collection>
	</resultMap>
	
	<select id="selectList" resultMap="detailResult">
		SELECT * 
		FROM project
	</select>
	
	<select id="selectDetail" parameterType="ProjectVO" resultMap="detailResult">
		SELECT *
		FROM project
		WHERE id = #{id}
	</select>
	
	<insert id="insert" parameterType="ProjectVO">
		INSERT INTO project
			(admin_id, title, summary, team_size, key_features, tech_stack
			,start_date, end_date, github_url, demo_url, ppt_url) 
		VALUES
			(#{adminId}, #{title}, #{summary}, #{teamSize}, #{keyFeatures}, #{techStack}
			,#{startDate}, #{endDate}, #{githubUrl}, #{demoUrl}, #{pptUrl});
	</insert>
	
	<update id="update" parameterType="ProjectVO">
		UPDATE project
		SET
			title = #{title}
			,summary = #{summary}
			,team_size = #{teamSize}
			,key_features = #{keyFeatures}
			,tech_stack = #{techStack}
			,start_date = #{startDate}
			,end_date = #{endDate}
			,github_url = #{githubUrl}
			,demo_url = #{demoUrl}
			,ppt_url = #{pptUrl}
		WHERE
			id = #{id}
			AND admin_id = #{adminId}
	</update>
	
	<delete id="delete" parameterType="ProjectVO">
		DELETE FROM project
		WHERE
			id = #{id}
			AND admin_id = #{adminId};
	</delete>
</mapper>